rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks that the document ID has a valid alphanumeric format and size to prevent resource poisoning.
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Checks if the user is an admin by querying the admins collection or checking matching role in users.
    // We also support the user email from runtime context (if any) or a dedicated system admin check in users.
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Helper for validating raw request payload data
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- COLLECTION RULES ---

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin(); // Prevent query scraping of PII lists
      allow create: if isOwner(userId)
        && incoming().id == userId
        && incoming().role in ['customer', 'artist', 'admin']
        && incoming().email is string && incoming().email.size() <= 100
        && incoming().name is string && incoming().name.size() <= 100;
        
      allow update: if isOwner(userId)
        && incoming().name is string && incoming().name.size() <= 100
        // Role and email are immutable for non-admins to prevent self-assigned privileges
        && incoming().role == existing().role
        && incoming().email == existing().email;

      allow delete: if isAdmin();
    }

    // 2. Artists Collection
    match /artists/{artistId} {
      allow read: if true; // Public listing is allowed
      allow create: if isOwner(artistId)
        && incoming().artistId == artistId
        && incoming().category in ['makeup', 'mehendi', 'hairsalon', 'photography', 'beautician']
        && incoming().city is string && incoming().city.size() <= 100
        && incoming().experience is int && incoming().experience >= 0
        && incoming().pricing is number && incoming().pricing >= 0
        && incoming().rating is number
        // Force the layout to start unverified; only an admin can verify
        && incoming().verified == false;

      allow update: if (isOwner(artistId) && (
        // Standard profile update
        incoming().artistId == artistId
        && incoming().category in ['makeup', 'mehendi', 'hairsalon', 'photography', 'beautician']
        && incoming().city is string && incoming().city.size() <= 100
        && incoming().experience is int && incoming().experience >= 0
        && incoming().pricing is number && incoming().pricing >= 0
        && incoming().verified == existing().verified // Artists cannot self-verify
      )) || isAdmin();

      allow delete: if isAdmin() || isOwner(artistId);
    }

    // 3. Services Collection
    match /services/{serviceId} {
      allow read: if true;
      allow create: if isSignedIn()
        && incoming().artistId == request.auth.uid
        && incoming().serviceName is string && incoming().serviceName.size() <= 100
        && incoming().price is number && incoming().price >= 0;

      allow update: if isSignedIn()
        && existing().artistId == request.auth.uid
        && incoming().artistId == request.auth.uid
        && incoming().serviceName is string && incoming().serviceName.size() <= 100
        && incoming().price is number && incoming().price >= 0;

      allow delete: if isSignedIn()
        && existing().artistId == request.auth.uid;
    }

    // 4. Bookings Collection
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.artistId == request.auth.uid || 
        isAdmin()
      );
      
      allow list: if isSignedIn(); // We allow listing but users will query filter on customerId or artistId

      allow create: if isSignedIn()
        && incoming().customerId == request.auth.uid
        && incoming().bookingStatus == 'pending'
        && incoming().bookingDate is string && incoming().bookingDate.size() == 10
        && incoming().bookingTime is string && incoming().bookingTime.size() <= 20
        && incoming().totalAmount is number && incoming().totalAmount >= 0;

      allow update: if isSignedIn() && (
        // The customer who booked can cancel the booking
        (resource.data.customerId == request.auth.uid && (
          incoming().bookingStatus == 'cancelled' &&
          incoming().diff(existing()).affectedKeys().hasOnly(['bookingStatus'])
        )) ||
        // The artist can confirm or complete bookings
        (resource.data.artistId == request.auth.uid && (
          incoming().bookingStatus in ['confirmed', 'completed', 'cancelled'] &&
          incoming().diff(existing()).affectedKeys().hasOnly(['bookingStatus'])
        )) ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // 5. Reviews Collection
    match /reviews/{reviewId} {
      // Reviews are public
      allow read: if true;
      
      allow create: if isSignedIn()
        && incoming().customerId == request.auth.uid
        && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5
        && incoming().comment is string && incoming().comment.size() <= 1000;

      // Reviews are immutable after writing to preserve honesty
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && existing().customerId == request.auth.uid);
    }

    // 6. Payments Collection
    match /payments/{paymentId} {
      allow get: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        isAdmin()
      );
      allow list: if isAdmin();

      allow create: if isSignedIn()
        && incoming().amount is number && incoming().amount >= 0
        && incoming().paymentStatus in ['pending', 'completed', 'refunded'];

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 7. Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn(); // Allow artists or customers to trigger notification writes
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['readStatus']); // Mark as read
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }
  }
}
