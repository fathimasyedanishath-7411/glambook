rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Server Proxy Synchronization Access ---
    // In this full-stack architecture, the client React SPA communicates exclusively with the Express backend API.
    // The Express backend acts as the sole secure mediator and proxy, using the Firestore client-side SDK inside Node.js
    // to load and save persistent data in an unauthenticated server context.
    // To support seamless database loading on startup and real-time syncing of memory caches,
    // the following collections permit unauthenticated reads and writes, while all other paths are strictly locked out.

    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // 2. Artists Collection
    match /artists/{artistId} {
      allow read, write: if true;
    }

    // 3. Services Collection
    match /services/{serviceId} {
      allow read, write: if true;
    }

    // 4. Bookings Collection
    match /bookings/{bookingId} {
      allow read, write: if true;
    }

    // 5. Reviews Collection
    match /reviews/{reviewId} {
      allow read, write: if true;
    }

    // 6. Payments Collection
    match /payments/{paymentId} {
      allow read, write: if true;
    }

    // 7. Notifications Collection
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
  }
}
